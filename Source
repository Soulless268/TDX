if not game:IsLoaded() then game.Loaded:Wait() end

local players = game:GetService("Players")

function checking(t, f, fallback)
	if type(f) == t then return f end
	return fallback
end

local queueteleport = checking("function", queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport))

local plr = players.LocalPlayer
local can_cross_ = true

local map = "SINGULARITY"
local difficulty = "Expert"
local autoAbility = false
local macroUrl = "https://raw.githubusercontent.com/NikitosZuev/Macro-url/refs/heads/main/Expert%20by%20N"

getgenv().EggHub = {
    Map = map,
    Difficulty = difficulty,
    AutoAbility = autoAbility,
    MacroUrl = macroUrl
}

loadstring(game:HttpGet("https://raw.githubusercontent.com/minh597/Egg/refs/heads/main/tdxmacro.lua"))()

plr.OnTeleport:Once(function()
	if queueteleport and can_cross_ then
		can_cross_ = false
		queueteleport([[
			local url = "https://raw.githubusercontent.com/Soulless268/TDX/refs/heads/main/Source"
			local maxAttempts = 5
			local delayTime = 2

			for i = 1, maxAttempts do
				local success, result = pcall(function()
					return game:HttpGet(url)
				end)

				if success and result then
					local func = loadstring(result)
					if func then
						print("debug")
						func()
						break
					end
				end

				warn("Attempt "..i.." failed, retrying...")
				task.wait(delayTime)
			end
		]])
	end
end)